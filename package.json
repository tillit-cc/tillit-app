{
  "name": "tillit-native",
  "main": "expo-router/entry",
  "version": "1.4.2",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "sim:ios": "expo run:ios --device ADF27FE3-58A7-4F51-99BF-FEBCE2CB7390",
    "sim:android": "expo run:android --device Pixel_9_Pro_API_35",
    "postinstall": "patch-package && ./scripts/download-arti.sh",
    "publish:ios": "npx eas-cli@latest build --platform ios --profile production --auto-submit",
    "publish:android": "npx eas-cli@latest build --platform android --profile production --auto-submit",
    "update:ios": "npx eas-cli@latest update --branch production --platform ios --message",
    "update:android": "npx eas-cli@latest update --branch production --platform android --message",
    "deploy": "npx eas-cli@latest workflow:run create-production-builds.yml",
    "rebuild": "expo prebuild --clean",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
