{
  "expo": {
    "name": "TilliT",
    "slug": "tillit",
    "version": "1.3.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tillitnative",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "locales": {
      "it": "./assets/locales/it.json",
      "en": "./assets/locales/en.json"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "45",
      "bundleIdentifier": "com.oglut.tillit.native",
      "appleTeamId": "663AVHG5AG",
      "associatedDomains": ["applinks:tillit.cc"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "it",
        "NSFaceIDUsageDescription": "TilliT utilizza Face ID per proteggere l'accesso ai tuoi messaggi crittografati.",
        "NSLocalNetworkUsageDescription": "TilliT cerca server sulla rete locale per collegamento automatico.",
        "NSBonjourServices": ["_tillit._tcp."],
        "NSAppTransportSecurity": {
          "NSExceptionDomains": {
            "onion": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2f4059",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "edgeToEdgeEnabled": true,
      "allowBackup": false,
      "package": "com.oglut.tillit.xnative",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tillit.cc",
              "pathPrefix": "/roomcode/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-sqlite", { "useSQLCipher": true }],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/hp.caf"
          ]
        }
      ],
      "./plugins/withLibSignalClient",
      "./plugins/withTorProxy",
      [
        "expo-image-picker",
        {
          "cameraPermission": "TilliT ha bisogno dell'accesso alla fotocamera per scattare foto da inviare nei messaggi.",
          "photosPermission": "TilliT ha bisogno dell'accesso alla galleria per selezionare foto da inviare nei messaggi."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2f4059",
          "dark": {
            "backgroundColor": "#2f4059"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "TilliT ha bisogno dell'accesso alla galleria per salvare le immagini ricevute.",
          "savePhotosPermission": "TilliT ha bisogno dell'accesso alla galleria per salvare le immagini ricevute.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 1,
            "NSExtensionActivationSupportsFileWithMaxCount": 1,
            "NSExtensionActivationSupportsAttachmentsWithMaxCount": 1
          },
          "androidIntentFilters": ["text/*", "image/*", "application/*"],
          "androidMultiIntentFilters": ["image/*"]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ea40f5a-9d6c-4a70-bbee-fcbe78d24b59"
      }
    },
    "owner": "oglut",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3ea40f5a-9d6c-4a70-bbee-fcbe78d24b59",
      "checkAutomatically": "NEVER"
    }
  }
}
