EXPO_PUBLIC_API_URL=https://api.tillit.cc
EXPO_PUBLIC_SOCKET_URL=https://api.tillit.cc

# Sender key encryption threshold (minimum members before using sender keys)
EXPO_PUBLIC_SENDER_KEY_THRESHOLD=3

# Sender key rotation settings
EXPO_PUBLIC_SENDER_KEY_MESSAGE_ROTATION=1000
EXPO_PUBLIC_SENDER_KEY_DAYS_ROTATION=7

# Chat page settings
EXPO_PUBLIC_PAGE_SIZE=35
